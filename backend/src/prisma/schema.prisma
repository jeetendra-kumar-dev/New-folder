generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum SubscriptionCategory {
  ENTERTAINMENT
  PRODUCTIVITY
  EDUCATION
  FINANCE
  HEALTH
  LIFESTYLE
  UTILITIES
  OTHER
}

enum GoalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum NotificationType {
  SUBSCRIPTION_RENEWAL
  GOAL_REMINDER
  MEMORY_INSIGHT
  SYSTEM
}

enum MemoryType {
  PREFERENCE
  FACT
  CONTEXT
  INSIGHT
  REMINDER
  OTHER
}

enum OtpPurpose {
  LOGIN
}

model User {
  id            String           @id @default(cuid())
  email         String           @unique @db.VarChar(255)
  name          String?          @db.VarChar(120)
  passwordHash  String?
  role          UserRole         @default(USER)
  emailVerified DateTime?
  sessions      RefreshSession[]
  subscriptions Subscription[]
  goals         Goal[]
  notifications Notification[]
  memories      Memory[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model EmailOtp {
  id         String     @id @default(cuid())
  email      String     @db.VarChar(255)
  codeHash   String
  purpose    OtpPurpose @default(LOGIN)
  attempts   Int        @default(0)
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([email])
  @@index([purpose])
  @@index([expiresAt])
  @@index([email, purpose])
  @@map("email_otps")
}

model RefreshSession {
  id        String    @id @default(cuid())
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_sessions")
}

model Subscription {
  id            String               @id @default(cuid())
  userId        String
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceName   String               @db.VarChar(120)
  renewalDate   DateTime
  amount        Decimal              @db.Decimal(12, 2)
  category      SubscriptionCategory @default(OTHER)
  autoRenew     Boolean              @default(true)
  reminderDays  Int[]                @default([7])
  notes         String?              @db.Text
  notifications Notification[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([userId])
  @@index([renewalDate])
  @@index([category])
  @@index([autoRenew])
  @@index([userId, renewalDate])
  @@map("subscriptions")
}

model Goal {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String         @db.VarChar(160)
  description     String?        @db.Text
  totalDays       Int
  completedDays   Int            @default(0)
  progressPercent Decimal        @default(0) @db.Decimal(5, 2)
  status          GoalStatus     @default(IN_PROGRESS)
  startedAt       DateTime       @default(now())
  targetDate      DateTime?
  completedAt     DateTime?
  notifications   Notification[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([userId])
  @@index([status])
  @@index([targetDate])
  @@index([userId, status])
  @@map("goals")
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId String?
  subscription   Subscription?    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  goalId         String?
  goal           Goal?            @relation(fields: [goalId], references: [id], onDelete: Cascade)
  type           NotificationType
  message        String           @db.Text
  isRead         Boolean          @default(false)
  readAt         DateTime?
  metadata       Json?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([userId])
  @@index([subscriptionId])
  @@index([goalId])
  @@index([type])
  @@index([isRead])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Memory {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           MemoryType @default(CONTEXT)
  title          String?    @db.VarChar(160)
  content        String     @db.Text
  importance     Int        @default(1)
  source         String?    @db.VarChar(120)
  metadata       Json?
  lastAccessedAt DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId])
  @@index([type])
  @@index([userId, type])
  @@index([userId, importance])
  @@index([lastAccessedAt])
  @@map("memories")
}
