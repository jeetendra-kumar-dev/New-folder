NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# DBeaver connection:
# Host: localhost
# Port: 5432
# Database: saas_starter
# Username: postgres
# Password: postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/saas_starter?schema=public"

JWT_ACCESS_SECRET="replace-with-a-strong-access-secret-at-least-32-chars"
JWT_REFRESH_SECRET="replace-with-a-strong-refresh-secret-at-least-32-chars"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
OTP_EXPIRES_IN_MINUTES=10
OTP_MAX_ATTEMPTS=5

CORS_ORIGIN=http://localhost:3000
BCRYPT_SALT_ROUNDS=12

# Optional real email delivery. When omitted, OTP codes are logged in development.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM="PocketPilot <no-reply@pocketpilot.local>"

# AI assistant and model studio (optional - without a key, local fallback models run from stored data)
# OPENAI_API_KEY=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
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini API (OpenAI-compatible) example:
# - Get an API key from Google AI Studio (often starts with "AIza...").
# - Base URL must be the OpenAI-compat endpoint, not the native Gemini "models/*:generateContent" endpoint.
# OPENAI_API_KEY=AIzaSy...
# OPENAI_MODEL=gemini-1.5-flash
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
